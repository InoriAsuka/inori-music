{
  "components": {
    "schemas": {
      "BackendConfig": {
        "additionalProperties": false,
        "description": "Exactly one property must be present and match the backend type.",
        "properties": {
          "distributed": {
            "$ref": "#/components/schemas/DistributedConfig"
          },
          "local": {
            "$ref": "#/components/schemas/LocalConfig"
          },
          "nfs": {
            "$ref": "#/components/schemas/NFSConfig"
          },
          "s3": {
            "$ref": "#/components/schemas/S3Config"
          },
          "smb": {
            "$ref": "#/components/schemas/SMBConfig"
          }
        },
        "type": "object"
      },
      "BackendType": {
        "enum": [
          "local",
          "nfs",
          "smb",
          "s3",
          "distributed"
        ],
        "type": "string"
      },
      "CapabilitySet": {
        "properties": {
          "crossNodeAccess": {
            "type": "boolean"
          },
          "multipartUpload": {
            "type": "boolean"
          },
          "nativeLifecyclePolicy": {
            "type": "boolean"
          },
          "presignedUrls": {
            "type": "boolean"
          },
          "requiresCredentialValidation": {
            "type": "boolean"
          },
          "requiresMountValidation": {
            "type": "boolean"
          },
          "serverRangeReads": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "CapacityReport": {
        "properties": {
          "availableBytes": {
            "minimum": 0,
            "type": "integer"
          },
          "backendId": {
            "type": "string"
          },
          "checkedAt": {
            "format": "date-time",
            "type": "string"
          },
          "totalBytes": {
            "minimum": 0,
            "type": "integer"
          },
          "usedBytes": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "backendId",
          "totalBytes",
          "availableBytes",
          "usedBytes",
          "checkedAt"
        ],
        "type": "object"
      },
      "DistributedConfig": {
        "additionalProperties": false,
        "properties": {
          "accessKeySecretRef": {
            "type": "string"
          },
          "adapter": {
            "enum": [
              "s3-compatible",
              "mounted-filesystem",
              "dedicated"
            ],
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "mountPath": {
            "type": "string"
          },
          "pathStyle": {
            "type": "boolean"
          },
          "region": {
            "type": "string"
          },
          "secretKeySecretRef": {
            "type": "string"
          }
        },
        "required": [
          "adapter"
        ],
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "properties": {
              "code": {
                "enum": [
                  "invalid_backend",
                  "unauthorized",
                  "not_found",
                  "method_not_allowed",
                  "conflict",
                  "probe_unsupported",
                  "probe_failed",
                  "capacity_unsupported",
                  "internal_error",
                  "admin_auth_not_configured"
                ],
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "type": "object"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "HealthStatus": {
        "enum": [
          "unknown",
          "healthy",
          "unhealthy",
          "disabled"
        ],
        "type": "string"
      },
      "LocalConfig": {
        "additionalProperties": false,
        "properties": {
          "rootPath": {
            "type": "string"
          }
        },
        "required": [
          "rootPath"
        ],
        "type": "object"
      },
      "NFSConfig": {
        "additionalProperties": false,
        "properties": {
          "expectedRemote": {
            "type": "string"
          },
          "mountPath": {
            "type": "string"
          }
        },
        "required": [
          "mountPath",
          "expectedRemote"
        ],
        "type": "object"
      },
      "ProbeResult": {
        "properties": {
          "backendId": {
            "type": "string"
          },
          "checkedAt": {
            "format": "date-time",
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          }
        },
        "required": [
          "backendId",
          "status"
        ],
        "type": "object"
      },
      "RefreshReport": {
        "properties": {
          "completedAt": {
            "format": "date-time",
            "type": "string"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/RefreshResult"
            },
            "type": "array"
          },
          "startedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "startedAt",
          "completedAt",
          "results"
        ],
        "type": "object"
      },
      "RefreshResult": {
        "properties": {
          "backendId": {
            "type": "string"
          },
          "capacity": {
            "$ref": "#/components/schemas/CapacityReport"
          },
          "errors": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "probe": {
            "$ref": "#/components/schemas/ProbeResult"
          },
          "skipped": {
            "type": "boolean"
          }
        },
        "required": [
          "backendId",
          "skipped"
        ],
        "type": "object"
      },
      "S3Config": {
        "additionalProperties": false,
        "properties": {
          "accessKeySecretRef": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "endpoint": {
            "format": "uri",
            "type": "string"
          },
          "pathStyle": {
            "type": "boolean"
          },
          "region": {
            "type": "string"
          },
          "secretKeySecretRef": {
            "type": "string"
          }
        },
        "required": [
          "endpoint",
          "bucket",
          "accessKeySecretRef",
          "secretKeySecretRef"
        ],
        "type": "object"
      },
      "SMBConfig": {
        "additionalProperties": false,
        "properties": {
          "expectedShare": {
            "type": "string"
          },
          "mountPath": {
            "type": "string"
          }
        },
        "required": [
          "mountPath",
          "expectedShare"
        ],
        "type": "object"
      },
      "StorageBackend": {
        "allOf": [
          {
            "$ref": "#/components/schemas/StorageBackendRequest"
          },
          {
            "properties": {
              "capabilities": {
                "$ref": "#/components/schemas/CapabilitySet"
              },
              "createdAt": {
                "format": "date-time",
                "type": "string"
              },
              "healthStatus": {
                "$ref": "#/components/schemas/HealthStatus"
              },
              "lastCapacity": {
                "$ref": "#/components/schemas/CapacityReport"
              },
              "lastHealthCheckAt": {
                "format": "date-time",
                "type": "string"
              },
              "updatedAt": {
                "format": "date-time",
                "type": "string"
              }
            },
            "type": "object"
          }
        ]
      },
      "StorageBackendRequest": {
        "additionalProperties": false,
        "properties": {
          "config": {
            "$ref": "#/components/schemas/BackendConfig"
          },
          "displayName": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          },
          "type": {
            "$ref": "#/components/schemas/BackendType"
          }
        },
        "required": [
          "id",
          "type",
          "displayName",
          "enabled",
          "config"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "opaque",
        "scheme": "bearer",
        "type": "http"
      }
    },
    "parameters": {
      "BackendId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Storage backend identifier assigned by the server-managed backend registry.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "info": {
    "description": "Server-managed media storage administration API.",
    "title": "Inori Music Storage Admin API",
    "version": "0.8.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/admin/storage/backends": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "backends": {
                      "items": {
                        "$ref": "#/components/schemas/StorageBackend"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "backends"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Backend list"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List configured storage backends."
      },
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageBackendRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageBackend"
                }
              }
            },
            "description": "Registered backend"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Validate and register a storage backend."
      }
    },
    "/api/v1/admin/storage/backends/refresh": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshReport"
                }
              }
            },
            "description": "Refresh report"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Refresh all enabled backend health and supported capacity state."
      }
    },
    "/api/v1/admin/storage/backends/validate": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageBackendRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageBackend"
                }
              }
            },
            "description": "Validated backend"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Validate a backend candidate without persisting it."
      }
    },
    "/api/v1/admin/storage/backends/{id}/capacity": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapacityReport"
                }
              }
            },
            "description": "Capacity report"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Read and record backend capacity where supported."
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/BackendId"
        }
      ]
    },
    "/api/v1/admin/storage/backends/{id}/default": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageBackend"
                }
              }
            },
            "description": "Default backend"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Select a backend as default."
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/BackendId"
        }
      ]
    },
    "/api/v1/admin/storage/backends/{id}/disable": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageBackend"
                }
              }
            },
            "description": "Disabled backend"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Disable a non-default backend."
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/BackendId"
        }
      ]
    },
    "/api/v1/admin/storage/backends/{id}/health": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProbeResult"
                }
              }
            },
            "description": "Probe result"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Read latest recorded backend health."
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/BackendId"
        }
      ]
    },
    "/api/v1/admin/storage/backends/{id}/probe": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProbeResult"
                }
              }
            },
            "description": "Probe result"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Run an on-demand backend probe."
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/BackendId"
        }
      ]
    },
    "/healthz": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "const": "ok",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Healthy"
          }
        },
        "security": [],
        "summary": "Return process health."
      }
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080"
    }
  ]
}
